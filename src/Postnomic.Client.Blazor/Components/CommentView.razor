@inject IPostnomicBlogService _injectedBlogService

<div class="comment mb-3 @(Depth > 0 ? "ms-4 border-start ps-3" : "")"
     style="@(Depth > 0 ? "border-left: 2px solid #dee2e6;" : "")">

    <div class="d-flex align-items-center mb-1">
        <strong class="me-2">@(string.IsNullOrWhiteSpace(Comment.AuthorName) ? "Anonymous" : Comment.AuthorName)</strong>
        <small class="text-muted">@Comment.CreatedAt.ToString("MMM dd, yyyy · HH:mm")</small>
    </div>

    @if (!string.IsNullOrEmpty(Comment.Subject))
    {
        <div class="fw-semibold mb-1">@Comment.Subject</div>
    }

    <p class="mb-1">@Comment.Body</p>

    @if (Post is not null && Post.CommentsEnabled)
    {
        <button class="btn btn-link btn-sm text-decoration-none p-0 mb-2"
                @onclick="ToggleReplyForm">
            @(showReplyForm ? "Cancel reply" : "↩ Reply")
        </button>
    }

    @if (showReplyForm)
    {
        <div class="reply-form border rounded p-3 mb-3 bg-light">
            @if (!string.IsNullOrEmpty(replySuccessMessage))
            {
                <div class="alert alert-success alert-sm py-2">@replySuccessMessage</div>
            }
            @if (!string.IsNullOrEmpty(replyErrorMessage))
            {
                <div class="alert alert-danger alert-sm py-2">@replyErrorMessage</div>
            }

            <div class="row">
                <div class="col-md-6 mb-2">
                    <label class="form-label small">
                        First name @if (Post!.CommentRequireFirstname) { <span class="text-danger">*</span> }
                    </label>
                    <input @bind="replyFirstname" class="form-control form-control-sm" />
                </div>
                <div class="col-md-6 mb-2">
                    <label class="form-label small">
                        Last name @if (Post.CommentRequireLastname) { <span class="text-danger">*</span> }
                    </label>
                    <input @bind="replyLastname" class="form-control form-control-sm" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-2">
                    <label class="form-label small">
                        Email @if (Post.CommentRequireEmail) { <span class="text-danger">*</span> }
                    </label>
                    <input @bind="replyEmail" class="form-control form-control-sm" type="email" />
                </div>
                <div class="col-md-6 mb-2">
                    <label class="form-label small">
                        Phone @if (Post.CommentRequirePhone) { <span class="text-danger">*</span> }
                    </label>
                    <input @bind="replyPhone" class="form-control form-control-sm" type="tel" />
                </div>
            </div>

            <div class="mb-2">
                <label class="form-label small">
                    Subject @if (Post.CommentRequireSubject) { <span class="text-danger">*</span> }
                </label>
                <input @bind="replySubject" class="form-control form-control-sm" />
            </div>

            <div class="mb-2">
                <label class="form-label small">Reply <span class="text-danger">*</span></label>
                <textarea @bind="replyBody" class="form-control form-control-sm" rows="3"></textarea>
            </div>

            <button class="btn btn-primary btn-sm" @onclick="SubmitReplyAsync" disabled="@isSubmittingReply">
                @(isSubmittingReply ? "Submitting…" : "Post reply")
            </button>
        </div>
    }

    @if (Comment.Replies.Count > 0)
    {
        @foreach (var reply in Comment.Replies)
        {
            <CommentView Comment="reply"
                         Depth="Depth + 1"
                         PostSlug="@PostSlug"
                         Post="Post"
                         OnCommentPosted="OnCommentPosted" />
        }
    }
</div>

@code {
    /// <summary>
    /// The comment to render. Required.
    /// </summary>
    [Parameter, EditorRequired]
    public PostnomicComment Comment { get; set; } = default!;

    /// <summary>
    /// The nesting depth of this comment. <c>0</c> for top-level, <c>1</c> for first-level replies, etc.
    /// Controls the left indentation applied to nested comments.
    /// </summary>
    [Parameter]
    public int Depth { get; set; }

    /// <summary>
    /// The URL-friendly slug of the post this comment belongs to. Used when submitting replies.
    /// </summary>
    [Parameter]
    public string PostSlug { get; set; } = "";

    /// <summary>
    /// The full post detail, used to determine which comment fields are required.
    /// <see langword="null"/> disables the reply button.
    /// </summary>
    [Parameter]
    public PostnomicPostDetail? Post { get; set; }

    /// <summary>
    /// Raised after a reply is successfully posted so the parent page can refresh the comment tree.
    /// </summary>
    [Parameter]
    public EventCallback OnCommentPosted { get; set; }

    [CascadingParameter]
    private PostnomicBlogContext? BlogContext { get; set; }

    private IPostnomicBlogService BlogService => BlogContext?.BlogService ?? _injectedBlogService;

    private bool showReplyForm;
    private string? replySubject;
    private string? replyBody;
    private string? replyFirstname;
    private string? replyLastname;
    private string? replyEmail;
    private string? replyPhone;
    private bool isSubmittingReply;
    private string? replySuccessMessage;
    private string? replyErrorMessage;

    private void ToggleReplyForm()
    {
        showReplyForm = !showReplyForm;
        if (!showReplyForm)
        {
            ResetReplyForm();
        }
    }

    private void ResetReplyForm()
    {
        replySubject = null;
        replyBody = null;
        replyFirstname = null;
        replyLastname = null;
        replyEmail = null;
        replyPhone = null;
        replySuccessMessage = null;
        replyErrorMessage = null;
    }

    private async Task SubmitReplyAsync()
    {
        if (string.IsNullOrWhiteSpace(replyBody)) return;

        isSubmittingReply = true;
        replySuccessMessage = null;
        replyErrorMessage = null;

        try
        {
            var request = new PostnomicCreateCommentRequest
            {
                ParentCommentPublicId = Comment.PublicId,
                Subject = replySubject,
                Body = replyBody!,
                AuthorFirstname = replyFirstname,
                AuthorLastname = replyLastname,
                AuthorEmail = replyEmail,
                AuthorPhone = replyPhone
            };

            var result = await BlogService.CreateCommentAsync(PostSlug, request);

            if (result is not null)
            {
                replySuccessMessage = Post?.CommentRequireModeration == true
                    ? "Your reply has been submitted and is awaiting moderation."
                    : "Your reply has been posted!";

                ResetReplyForm();
                showReplyForm = false;
                await OnCommentPosted.InvokeAsync();
            }
            else
            {
                replyErrorMessage = "Failed to post reply. Please try again.";
            }
        }
        catch (Exception ex)
        {
            replyErrorMessage = ex.Message;
        }
        finally
        {
            isSubmittingReply = false;
        }
    }
}
