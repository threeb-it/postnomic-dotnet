@inject IPostnomicBlogService _injectedBlogService

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title fw-bold mb-3">
            <i class="bi bi-tags"></i> Tags
        </h5>
        @if (tags is null)
        {
            <p class="text-muted"><em>Loading…</em></p>
        }
        else if (tags.Count == 0)
        {
            <p class="text-muted small">No tags found.</p>
        }
        else
        {
            <div class="d-flex flex-wrap gap-1">
                @foreach (var tag in tags)
                {
                    var isActive = tag.Slug == ActiveTagSlug;
                    <button class="btn btn-sm @(isActive ? "btn-secondary" : "btn-outline-secondary")"
                            @onclick="() => OnTagSelectedAsync(tag.Slug)">
                        @tag.Name <span class="badge bg-light text-dark ms-1">@tag.PostCount</span>
                    </button>
                }
            </div>
            @if (!string.IsNullOrEmpty(ActiveTagSlug))
            {
                <button class="btn btn-link btn-sm text-decoration-none mt-2 p-0"
                        @onclick="ClearFilterAsync">
                    &#10005; Clear filter
                </button>
            }
        }
    </div>
</div>

@code {
    /// <summary>
    /// The currently active tag slug filter, if any.
    /// <see langword="null"/> when no tag filter is applied.
    /// </summary>
    [Parameter]
    public string? ActiveTagSlug { get; set; }

    /// <summary>
    /// Raised when the user selects a tag or clears the tag filter.
    /// The argument is the tag slug, or <see langword="null"/> to clear the filter.
    /// </summary>
    [Parameter]
    public EventCallback<string?> OnFilterChanged { get; set; }

    [CascadingParameter]
    private PostnomicBlogContext? BlogContext { get; set; }

    private IPostnomicBlogService BlogService => BlogContext?.BlogService ?? _injectedBlogService;

    private List<PostnomicTag>? tags;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        try
        {
            tags = await BlogService.GetTagsAsync();
        }
        catch
        {
            tags = [];
        }
    }

    private async Task OnTagSelectedAsync(string slug)
    {
        await OnFilterChanged.InvokeAsync(slug == ActiveTagSlug ? null : slug);
    }

    private async Task ClearFilterAsync()
    {
        await OnFilterChanged.InvokeAsync(null);
    }
}
