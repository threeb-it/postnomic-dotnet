@inject IPostnomicBlogService _injectedBlogService
@inject IOptions<PostnomicClientOptions> _injectedClientOptions

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title fw-bold mb-3">
            <i class="bi bi-eye"></i> Most Read Posts
        </h5>
        @if (posts is null)
        {
            <p class="text-muted"><em>Loading…</em></p>
        }
        else if (posts.Count == 0)
        {
            <p class="text-muted small">No posts found.</p>
        }
        else
        {
            <ul class="list-group list-group-flush">
                @foreach (var post in posts)
                {
                    <li class="list-group-item px-0 d-flex justify-content-between align-items-start">
                        <a href="@($"{BasePath}/post/{post.Slug}")"
                           class="text-decoration-none text-dark fw-semibold">
                            @post.Title
                        </a>
                        <span class="badge bg-primary rounded-pill ms-2">
                            @post.Count.ToString("N0") <i class="bi bi-eye-fill"></i>
                        </span>
                    </li>
                }
            </ul>
        }
    </div>
</div>

@code {
    [CascadingParameter]
    private PostnomicBlogContext? BlogContext { get; set; }

    private IPostnomicBlogService BlogService => BlogContext?.BlogService ?? _injectedBlogService;
    private string BasePath => BlogContext?.Options.BasePath ?? _injectedClientOptions.Value.BasePath;

    private List<PostnomicPopularPost>? posts;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        try
        {
            posts = await BlogService.GetMostReadPostsAsync(count: 3);
        }
        catch
        {
            posts = [];
        }
    }
}
